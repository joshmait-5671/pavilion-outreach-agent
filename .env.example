# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth for Gmail (download from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=auth/client_secrets.json
GMAIL_TOKEN_PATH=auth/gmail_token.json

# Google Sheets - service account JSON path (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_PATH=auth/service_account.json

# Hunter.io (optional but recommended - https://hunter.io/api)
HUNTER_API_KEY=

# SerpAPI (optional - falls back to DuckDuckGo scraping)
SERPAPI_KEY=

# Slack — Recapper bot in Pavilion Executive workspace
# Required scopes on the bot: chat:write, im:write, im:read, im:history, reactions:read
# (the last two need to be added by reinstalling the app — see README)
SLACK_BOT_TOKEN=xoxb-...
SLACK_JOSH_USER_ID=UF4HKP3A6

# App config
DB_PATH=data/outreach.db
LOG_LEVEL=INFO
